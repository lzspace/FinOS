{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-os.local/finance/schemas/forecast_commands.schema.json",
  "title": "Finance Extension 0.5.0 recurring and forecast commands",
  "type": "object",
  "additionalProperties": false,
  "required": ["command_id", "command_type", "idempotency_key", "payload"],
  "properties": {
    "command_id": { "type": "string", "pattern": "^cmd_[a-f0-9]{32}$" },
    "command_type": { "enum": ["DetectRecurringPatterns", "ConfirmRecurringPattern", "RejectRecurringPattern", "UpdateRecurringPattern", "PauseRecurringPattern", "EndRecurringPattern", "CreateExpectedTransaction", "CancelExpectedTransaction", "CreateForecast", "EvaluateForecast", "SupersedeForecast"] },
    "idempotency_key": { "type": "string", "minLength": 8 },
    "payload": { "type": "object" }
  }
}
