{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-os.local/finance/schemas/migration_status.response.schema.json",
  "type": "object",
  "required": ["schema_version", "state", "projection_sequence", "event_store_sequence", "data"],
  "properties": {
    "schema_version": { "const": "1.0.0" },
    "state": { "type": "string" },
    "projection_sequence": { "type": "integer", "minimum": 0 },
    "event_store_sequence": { "type": "integer", "minimum": 0 },
    "data": {
      "type": "object",
      "required": ["current_store_schema_version", "supported_store_schema_version", "status", "history", "downgrade_protection"],
      "properties": {
        "current_store_schema_version": { "type": "integer", "minimum": 1 },
        "supported_store_schema_version": { "type": "integer", "minimum": 1 },
        "status": { "enum": ["CURRENT", "MIGRATION_REQUIRED", "DOWNGRADE_BLOCKED"] },
        "history": { "type": "array", "items": { "type": "object" } },
        "downgrade_protection": { "const": "ENABLED" }
      }
    }
  }
}
