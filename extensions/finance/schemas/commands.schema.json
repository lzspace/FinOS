        "approval_id": { "$ref": "#/$defs/LocalApprovalId" }
      }
    },
    "ReopenFinancialPeriodPayload": {
      "type": "object",
      "additionalProperties": false,
      "required": ["financial_period_id", "reason", "approval_id"],
      "properties": {
        "financial_period_id": { "$ref": "common.schema.json#/$defs/EntityId" },
        "reason": { "type": "string", "minLength": 1, "maxLength": 1000 },
        "approval_id": { "$ref": "#/$defs/LocalApprovalId" }
      }
    },
    "DeleteImportBatchPayload": {
      "type": "object",
      "additionalProperties": false,
